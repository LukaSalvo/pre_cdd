# Variables d'environnement pour le raccordement LDAP UL
# Copier ce fichier en .env et remplir avec vos identifiants
# cp .env.example .env

# ==========================================================
# Identifiants de connexion au LDAP de l'UL
# ==========================================================
# LDAP_DN: Format UPN pour Active Directory
LDAP_DN=votre_login@univ-lorraine.fr

# LDAP_PASS: Votre mot de passe UL
LDAP_PASS=votre_mot_de_passe_ul

# ==========================================================
# (Optionnel) Configuration de la base de données
# Laissez tel quel pour les valeurs par défaut
# ==========================================================
DB_USER=bookstack
DB_PASS=bookstack_pass
DB_DATABASE=bookstackapp
DB_ROOT_PASS=secret

# ==========================================================
# Application URL
# ==========================================================
APP_URL=http://localhost:6875

# ==========================================================
# Certificats LDAP
# ==========================================================
# Option B (Développement): Ignorer la vérification du certificat
LDAP_TLS_INSECURE=true

# Option A (Production): Chemin du certificat CA
# Si vous utilisez un certificat interne, commentez LDAP_TLS_INSECURE et décommentez ceci :
# LDAP_TLS_CA_CERT=/config/ul-ca.crt
