# Variables d'environnement pour BookStack + LDAP UL
# Copier ce fichier en .env et remplir avec vos identifiants
#   cp .env.example .env
# Le fichier .env est dans .gitignore : ne jamais le commiter.

# ==========================================================
# Authentification LDAP — Compte de bind (service)
# ==========================================================
# Format UPN obligatoire pour l'Active Directory de l'UL
LDAP_DN=votre_login@univ-lorraine.fr

# Mot de passe du compte de bind
LDAP_PASS=votre_mot_de_passe_ul

# ==========================================================
# Configuration de la base de données (valeurs par défaut)
# ==========================================================
DB_USER=bookstack
DB_PASS=bookstack_pass
DB_DATABASE=bookstackapp
DB_ROOT_PASS=secret

# ==========================================================
# URL publique de l'application
# ==========================================================
APP_URL=http://localhost:6875

# ==========================================================
# Clé de chiffrement de l'application (générée une seule fois)
# Laisser vide au premier lancement, BookStack la génère.
# ==========================================================
APP_KEY=

# ==========================================================
# Certificat TLS LDAP
# ==========================================================
# Option B (développement) : ignorer la vérification du certificat CA
LDAP_TLS_INSECURE=true

# Option A (production) : commenter la ligne ci-dessus et décommenter
# les lignes suivantes, en fournissant le fichier ul-ca.crt :
# LDAP_TLS_INSECURE=false
# (monter ul-ca.crt dans le conteneur via le volume dans docker-compose.yml)
